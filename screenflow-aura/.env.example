# ScreenFlow AURA — Environment Variables
# Copy this file to .env and fill in your values

# Required: Flask session signing key
SECRET_KEY=your_secret_key_here

# Required: Anthropic API key for Claude AI analysis
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# API key seeded into DB on first run (can manage multiple keys via DB)
AURA_API_KEY=your_aura_api_key_here

# Port (default 8083)
PORT=8083

# Set to true when running behind HTTPS reverse proxy (e.g. Caddy)
HTTPS=false

# Admin token for key management endpoints (/api/admin/keys)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AURA_ADMIN_TOKEN=your_admin_token_here
