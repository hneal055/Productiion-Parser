{
  "name": "My Dev Container",
  "image": "node:16", // Base image
  "remoteUser": "node",
  "customizations": {
    "vscode": {
      "settings": {
        "editor.formatOnSave": true // VS Code settings
      },
      "extensions": [
        "dbaeumer.vscode-eslint", // VS Code extensions
        "ms-python.python"
      ]
    }
  },
  "forwardPorts": [3000], // Ports to forward
  "postCreateCommand": "npm install" // Commands to run after creation
}
