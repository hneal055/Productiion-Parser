# Contract Review Tool — Environment Variables
# Copy this file to .env and fill in your values

# Required: Flask session signing key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your_secret_key_here

# Admin credentials (multi-user auth)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password_here

# Required: Anthropic API key for Claude AI analysis
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Set to true when running behind HTTPS reverse proxy (e.g. Caddy)
HTTPS=false
